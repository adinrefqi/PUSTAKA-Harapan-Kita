<?xml version="1.0" encoding="utf-8"?>
<!-- Splash: latar gradient hijau + logo & nama di tengah -->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/splash_background">

    <LinearLayout
        android:id="@+id/splash_konten"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:orientation="vertical">

        <!-- Logo aplikasi (taruh logo.png di res/drawable/logo.png) -->
        <ImageView
            android:layout_width="130dp"
            android:layout_height="130dp"
            android:padding="14dp"
            android:background="@drawable/splash_logo_bg"
            android:src="@drawable/logo"
            android:scaleType="fitCenter"
            android:contentDescription="Logo Pustaka Tunas Harapan" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="Pustaka Tunas Harapan"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:alpha="0.85"
            android:text="SMP Tunas Hidup Harapan Kita"
            android:textColor="#FFFFFF"
            android:textSize="13sp" />

    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="32dp"
        android:alpha="0.8"
        android:text="Perpustakaan Digital Sekolah"
        android:textColor="#FFFFFF"
        android:textSize="12sp" />

</RelativeLayout>
